// Calend'Air — schéma multi-tenant (normalisation des RDV, toutes sources)
// PostgreSQL via Prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  STAFF
}

/// Timeline relances : AT_RISK après T-6 ; NO_SHOW_PROBABLE après T-1 (rebooking préventif)
enum AppointmentStatus {
  PENDING
  CONFIRMED
  AT_RISK
  NO_SHOW_PROBABLE
  CANCELLED
  NO_SHOW
  COMPLETED
}

/// MVP : CSV + image + manuel ; Google Calendar = phase optionnelle
enum AppointmentSource {
  CSV
  IMAGE
  MANUAL
  GOOGLE_CALENDAR
}

enum ActionTokenPurpose {
  CONFIRM
  CANCEL
  REBOOK
}

enum CalendarProvider {
  GOOGLE
}

model Organization {
  id                         String   @id @default(uuid())
  name                       String
  slug                       String   @unique
  timezone                   String   @default("Europe/Paris")
  /// Tarif d’une séance (centimes) — utilisé pour le montant récupéré sur les RDV rebookés
  sessionPriceCents          Int      @default(0)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  users               User[]
  patients            Patient[]
  appointments        Appointment[]
  calendarConnections CalendarConnection[]
  waitlistEntries     WaitlistEntry[]
  freeSlots                    FreeSlot[]
  dailyReportLogs              DailyReportLog[]
  planningImportReminderLogs   PlanningImportReminderLog[]
}

/// Un e-mail « pensez à importer le planning de demain » par org et par jour d’envoi (fuseau org)
model PlanningImportReminderLog {
  id             String   @id @default(uuid())
  organizationId String
  /// Jour calendaire (YYYY-MM-DD) dans Organization.timezone au moment de l’envoi
  dayKey         String
  sentAt         DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, dayKey])
  @@index([organizationId])
}

/// Un envoi de rapport par org et par jour « métier » (YYYY-MM-DD fuseau org)
model DailyReportLog {
  id             String   @id @default(uuid())
  organizationId String
  dayKey         String
  sentAt         DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, dayKey])
  @@index([organizationId])
}

model User {
  id             String   @id @default(uuid())
  organizationId String
  email          String
  passwordHash   String?
  role           UserRole @default(STAFF)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  refreshTokens  RefreshToken[]

  @@unique([organizationId, email])
  @@index([organizationId])
}

/// Jeton de session longue durée (hash SHA-256 du secret brut côté client)
model RefreshToken {
  id        String @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Patient {
  id             String   @id @default(uuid())
  organizationId String
  email          String?
  phone          String?
  name           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  appointments    Appointment[]
  waitlistEntries WaitlistEntry[]

  @@index([organizationId])
  @@index([organizationId, email])
}

model CalendarConnection {
  id                    String           @id @default(uuid())
  organizationId        String
  provider              CalendarProvider
  /// Jeton de rafraîchissement chiffré (OAuth Google, phase optionnelle)
  refreshTokenEncrypted String
  calendarId            String
  accountEmail          String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider, calendarId])
  @@index([organizationId])
}

model Appointment {
  id              String            @id @default(uuid())
  organizationId  String
  patientId       String?
  externalEventId String?
  title           String
  startsAt        DateTime
  endsAt          DateTime
  status          AppointmentStatus @default(PENDING)
  source          AppointmentSource @default(MANUAL)
  confirmedAt     DateTime?
  cancelledAt     DateTime?
  lastSyncedAt    DateTime?
  /// Regroupe les RDV issus d’un même import CSV (Lot 2)
  importBatchId   String?
  /// Feedback optionnel à l’annulation (fiche 5.5)
  cancellationReason String?
  /// Ancien J-1 — doublon logique de reminderT24SentAt (reprise migration)
  reminderJ1SentAt   DateTime?
  /// Ancien H-3 — doublon logique T-6/T-3 (reprise migration)
  reminderH3SentAt   DateTime?
  /// T-24h : premier e-mail (rappel + confirmer / annuler)
  reminderT24SentAt  DateTime?
  /// T-6h : relance multi-canal (e-mail + stub WhatsApp)
  reminderT6SentAt   DateTime?
  /// T-3h : escalade (message plus direct)
  reminderT3SentAt   DateTime?
  /// T-1h : dernière tentative + no-show probable + créneau offert liste d’attente
  reminderT1SentAt   DateTime?
  preventiveRebookOfferedAt DateTime?
  /// Score confirmation (+ confirm, − silences / relances)
  confirmationScore  Int               @default(0)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient         Patient?     @relation(fields: [patientId], references: [id], onDelete: SetNull)
  actionTokens    ActionToken[]
  freeSlotCreated FreeSlot?    @relation("CreatedFromAppointment")

  @@index([organizationId, startsAt])
  @@index([organizationId, status])
  @@index([organizationId, importBatchId])
  @@index([externalEventId])
}

model ActionToken {
  id            String             @id @default(uuid())
  appointmentId String
  /// Hachage (ex. SHA-256) du secret — jamais stocker le lien brut
  tokenHash     String
  purpose       ActionTokenPurpose
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime           @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@unique([tokenHash])
  @@index([appointmentId])
}

model FreeSlot {
  id                  String    @id @default(uuid())
  organizationId      String
  sourceAppointmentId String?   @unique
  startsAt            DateTime
  endsAt              DateTime
  filledAt            DateTime?
  createdAt           DateTime  @default(now())

  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sourceAppointment Appointment? @relation("CreatedFromAppointment", fields: [sourceAppointmentId], references: [id], onDelete: SetNull)
  rebookingOffers   RebookingOffer[]

  @@index([organizationId, startsAt])
}

model WaitlistEntry {
  id             String   @id @default(uuid())
  organizationId String
  patientId      String?
  serviceType    String?
  priority       Int      @default(0)
  notes          String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient      Patient?        @relation(fields: [patientId], references: [id], onDelete: SetNull)
  offers       RebookingOffer[]

  @@index([organizationId, active])
}

model RebookingOffer {
  id              String    @id @default(uuid())
  freeSlotId      String
  waitlistEntryId String
  sentAt          DateTime?
  claimedAt       DateTime?
  /// Hachage du jeton brut (lien « Réserver en 1 clic »)
  tokenHash       String?   @unique
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())

  freeSlot      FreeSlot      @relation(fields: [freeSlotId], references: [id], onDelete: Cascade)
  waitlistEntry WaitlistEntry @relation(fields: [waitlistEntryId], references: [id], onDelete: Cascade)

  @@unique([freeSlotId, waitlistEntryId])
  @@index([freeSlotId])
}
