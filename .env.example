# PostgreSQL (ex. local : postgresql://postgres:postgres@localhost:5432/calendair)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/calendair?schema=public"

# API
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Liens Confirmer / Annuler (sans slash final) — ex. https://votre-api.com ou http://localhost:3000
PUBLIC_APP_URL="http://localhost:3000"

# Resend (https://resend.com) — sans clé, les relances ne partent pas (voir POST run-reminders)
RESEND_API_KEY=""

# Expéditeur vérifié chez Resend ; en test : Calend'Air <onboarding@resend.dev>
EMAIL_FROM="Calend'Air <onboarding@resend.dev>"

# Optionnel : Authorization: Bearer <secret> sur POST /api/internal/run-reminders
# CRON_SECRET=""

# Heure locale (fuseau de chaque Organization) pour l’email « Rapport du jour » (0–23)
# DAILY_REPORT_LOCAL_HOUR=8

# Heure locale pour l’e-mail « importez le planning de demain » (0–23, défaut 18)
# PLANNING_IMPORT_EMAIL_LOCAL_HOUR=18

# JWT (connexion cabinet) — min. 16 caractères ; en prod : secret long et aléatoire
# JWT_SECRET="votre-secret-tres-long"
# Durée du jeton d’accès (ex. 15m, 1h) et du refresh (jours) — voir Lot 8 README
# JWT_ACCESS_EXPIRES=15m
# JWT_REFRESH_DAYS=30

# Optionnel : relances WhatsApp / appel (webhook POST JSON : channel, phone, message, appointmentId)
# REMINDER_WEBHOOK_URL="https://..."

# Optionnel : structuration des rendez-vous après OCR (POST .../imports/image/analyze)
# OPENAI_API_KEY=""
